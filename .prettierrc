{
	"semi": false,
	"printWidth": 80,
	"useTabs": true,
	"tabWidth": 2,
	"singleQuote": true,
	"trailingComma": "none",
	"endOfLine": "lf",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"arrowParens": "avoid",
	"plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		}
	]
}
