---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import PageHead from '@/components/page-head.astro'
import { Badge } from '@/components/ui/badge'
import Layout from '@/layouts/layout.astro'

const topics = [
	{
		category: 'Build',
		items: ['layout', 'case', 'plate', 'stabilizer', 'mounting style']
	},
	{
		category: 'Typing feel',
		items: ['linear', 'tactile', 'spring weight', 'sound profile']
	},
	{
		category: 'Keycap',
		items: ['profile', 'material', 'kitting', 'compatibility']
	}
]
---

<Layout class="max-w-3xl">
	<PageHead slot="head" title="About" />
	<Breadcrumbs
		items={[{ label: 'About', href: '/about', icon: 'lucide:user' }]}
	/>

	<section class="not-prose flex flex-col gap-4">
		<h1 class="text-3xl font-semibold tracking-tight">About Keeb Log</h1>
		<p class="text-muted-foreground leading-relaxed">
			Keeb Log là blog lưu trữ ghi chú về bàn phím cơ custom bằng tiếng Việt.
			Nội dung tập trung vào quyết định thực tế khi build: chọn layout, switch,
			keycap, plate, foam, stabilizer và các trade-off giữa âm gõ, cảm giác gõ
			và độ tiện dụng hằng ngày.
		</p>
		<p class="text-muted-foreground leading-relaxed">
			Mục tiêu không phải chạy theo cấu hình đắt nhất, mà là ghi lại cách chọn
			part có lý do, dễ kiểm chứng và có thể tham khảo lại cho các build sau.
		</p>
	</section>

	<section class="not-prose mt-8 flex flex-col gap-y-4">
		<h2 class="text-lg font-semibold">Chủ đề chính</h2>
		<div class="flex flex-col gap-y-3">
			{
				topics.map(group => (
					<div class="flex flex-col gap-y-1.5">
						<span class="text-muted-foreground text-xs font-medium">
							{group.category}
						</span>
						<div class="flex flex-wrap gap-1.5">
							{group.items.map(item => (
								<Badge variant="muted">{item}</Badge>
							))}
						</div>
					</div>
				))
			}
		</div>
	</section>
</Layout>
