---
import { withBasePath } from '@/lib/utils'
---

<link
	rel="icon"
	type="image/png"
	href={withBasePath('/favicon-16x16.png')}
	sizes="16x16"
/>
<link
	rel="icon"
	type="image/png"
	href={withBasePath('/favicon-32x32.png')}
	sizes="32x32"
/>
<!-- <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" /> -->
<!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" /> -->
<link rel="shortcut icon" href={withBasePath('/favicon.ico')} />
<link
	rel="apple-touch-icon"
	sizes="180x180"
	href={withBasePath('/apple-touch-icon.png')}
/>
<meta name="apple-mobile-web-app-title" content="Keeb Log" />
<link rel="manifest" href={withBasePath('/site.webmanifest')} />
